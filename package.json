{
  "name": "@ago-dev/nx-aws-cdk-v2",
  "description": "nx aws-cdk-v2 plugin",
  "author": {
    "name": "Adrian Görisch",
    "email": "github@ago-dev.org"
  },
  "license": "MIT",
  "homepage": "https://github.com/ago-devlab/nx-plugins",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adrian-goe/nx-aws-cdk-v2"
  },
  "scripts": {
    "nx": "nx",
    "lint-stage": "lint-staged",
    "commitlint": "commitlint",
    "test": "nx test aws-cdk-v2",
    "lint": "nx lint aws-cdk-v2",
    "format": "nx format:write",
    "e2e:aws-cdk": "nx e2e aws-cdk-v2-e2e",
    "build:aws-cdk": "nx build aws-cdk-v2",
    "link:aws-cdk": "cd dist/packages/aws-cdk-v2 && npm link"
  },
  "private": true,
  "dependencies": {
    "aws-cdk": "3.0.0",
    "aws-cdk-lib": "2.233.0",
    "constructs": "10.4.4",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@angular-devkit/architect": "0.2100.4",
    "@angular-devkit/core": "21.0.4",
    "@angular-devkit/schematics": "21.0.4",
    "@commitlint/cli": "20.3.0",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.8",
    "@types/jest": "30.0.0",
    "@types/node": "24.10.4",
    "@typescript-eslint/eslint-plugin": "5.62.0",
    "@typescript-eslint/parser": "5.62.0",
    "dotenv": "17.2.3",
    "eslint": "8.57.1",
    "eslint-config-prettier": "8.10.2",
    "eslint-plugin-cdk": "1.8.0",
    "eslint-plugin-json": "4.0.1",
    "jest": "30.2.0",
    "jest-environment-jsdom": "30.2.0",
    "nx": "22.3.3",
    "prettier": "3.7.4",
    "ts-jest": "29.4.6",
    "ts-node": "10.9.2",
    "tslib": "2.8.1",
    "typescript": "5.9.3",
    "@nx/devkit": "22.3.3",
    "@nx/workspace": "22.3.3",
    "@nx/js": "22.3.3",
    "@nx/linter": "19.8.4",
    "@nx/eslint-plugin": "22.3.3",
    "@nx/plugin": "22.3.3",
    "@nx/jest": "22.3.3",
    "@nx/node": "22.3.3"
  },
  "files": [
    "src/*",
    "cli/*",
    "lib/*",
    "peers/*",
    "scripts/*.js",
    "stubs/*.stub.js",
    "nesting/*",
    "types/**/*",
    "*.d.ts",
    "*.css",
    "*.js"
  ],
  "lint-staged": {
    "*.{js,json,css,scss,md,ts,html,graphql}": [
      "npm run format --uncommitted"
    ]
  }
}
